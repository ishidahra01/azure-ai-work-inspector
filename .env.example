AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ANALYSIS_MODEL=gpt-5.4-mini
AZURE_OPENAI_REPORT_MODEL=gpt-5.4

# If AZURE_OPENAI_API_KEY is empty, the app falls back to DefaultAzureCredential.
# Ensure the runtime identity has a role such as Cognitive Services OpenAI User.

DEFAULT_LLM_PROVIDER=azure_openai

FOUNDRY_CLAUDE_BASE_URL=https://<your-resource-name>.services.ai.azure.com/anthropic
FOUNDRY_CLAUDE_API_KEY=
FOUNDRY_CLAUDE_ANALYSIS_MODEL=claude-sonnet-4-6
FOUNDRY_CLAUDE_REPORT_MODEL=claude-sonnet-4-6

AGENT_WORKSPACE_URL=http://127.0.0.1:8088/responses
AGENT_WORKSPACE_REQUEST_TIMEOUT=180

CLAUDE_CODE_USE_POWERSHELL_TOOL=1
CLAUDE_CODE_USE_FOUNDRY=1
CLAUDE_PERMISSION_MODE=dontAsk
CLAUDE_MODEL=sonnet
CLAUDE_EFFORT=high

ANTHROPIC_FOUNDRY_RESOURCE=
ANTHROPIC_FOUNDRY_BASE_URL=https://<your-foundry-resource>.services.ai.azure.com/anthropic
ANTHROPIC_FOUNDRY_API_KEY=
ANTHROPIC_DEFAULT_OPUS_MODEL=
ANTHROPIC_DEFAULT_SONNET_MODEL=
ANTHROPIC_DEFAULT_HAIKU_MODEL=

# If FOUNDRY_CLAUDE_API_KEY is empty, the app falls back to DefaultAzureCredential.
# Ensure the runtime identity can access the Foundry resource.

BLOB_CONNECTION_STRING=
BLOB_CONTAINER_NAME=